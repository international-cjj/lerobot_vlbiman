<mujoco model="TRLC-DK1-Follower">
  <compiler angle="radian"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast" solver="Newton" iterations="100"/>

  <default>
    <geom friction="1.2 0.02 0.002" solref="0.003 1" solimp="0.95 0.99 0.001" condim="4"/>
    <joint damping="4.0" armature="0.01"/>
    <default class="arm_visual">
      <geom type="mesh"/>
    </default>
    <default class="finger_visual">
      <geom type="mesh" contype="0" conaffinity="0"/>
    </default>
    <default class="finger_collision">
      <geom type="box" rgba="0.35 0.35 0.35 0.20" friction="1.5 0.08 0.002" solref="0.003 1" solimp="0.96 0.995 0.001"/>
    </default>
    <default class="finger_pad">
      <geom type="box" rgba="0.90 0.25 0.25 0.35" friction="2.4 0.18 0.01" solref="0.002 1" solimp="0.98 0.999 0.001"/>
    </default>
    <default class="joint_position">
      <position kp="250" ctrllimited="true" forcelimited="true"/>
    </default>
  </default>

  <asset>
    <mesh name="base_link" content_type="model/stl" file="base_link.stl"/>
    <mesh name="link1-2" content_type="model/stl" file="link1-2.stl"/>
    <mesh name="link2-3" content_type="model/stl" file="link2-3.stl"/>
    <mesh name="link3-4" content_type="model/stl" file="link3-4.stl"/>
    <mesh name="link4-5" content_type="model/stl" file="link4-5.stl"/>
    <mesh name="link5-6" content_type="model/stl" file="link5-6.stl"/>
    <mesh name="link6-7" content_type="model/stl" file="link6-7.stl"/>
    <mesh name="finger_left" content_type="model/stl" file="finger_left.stl"/>
    <mesh name="finger_right" content_type="model/stl" file="finger_right.stl"/>
  </asset>

  <worldbody>
    <light name="key_light" pos="1.5 -1.0 2.5" dir="-0.5 0.3 -1" diffuse="0.9 0.9 0.9"/>
    <light name="fill_light" pos="-1.0 1.0 1.8" dir="0.5 -0.2 -1" diffuse="0.4 0.4 0.4"/>

    <geom name="floor_geom" type="box" size="2 2 0.02" pos="0 0 -0.03" rgba="0.68 0.55 0.42 1"/>

    <body name="arm_base" pos="0 0 0">
      <geom name="base_link_visual" class="arm_visual" mesh="base_link"/>
      <body name="link1-2" pos="0 0 0.0615">
        <inertial pos="0.0054231 0 0.017086" quat="0.653281 0.653281 -0.270598 0.270598" mass="0.0886" diaginertia="9e-05 7e-05 3e-05"/>
        <joint name="joint1" pos="0 0 0" axis="0 0 1" range="-2.0944 2.0944" actuatorfrcrange="-100 100" damping="6.0" armature="0.03"/>
        <geom name="link1-2_visual" class="arm_visual" mesh="link1-2"/>
        <body name="link2-3" pos="0.02 0 0.0385">
          <inertial pos="0.132 0 0" quat="7.64729e-05 0.706196 -0.000379919 0.708016" mass="1.0327" diaginertia="0.0160501 0.01599 0.000509891"/>
          <joint name="joint2" pos="0 0 0" axis="0 -1 0" range="-3.14159 0.01" actuatorfrcrange="-100 100" damping="18.0" armature="0.08"/>
          <geom name="link2-3_visual" class="arm_visual" mesh="link2-3"/>
          <body name="link3-4" pos="-0.264 0 0">
            <inertial pos="0.18531 0.00068376 0.051638" quat="0.162774 0.718019 0.185661 0.650756" mass="0.6073" diaginertia="0.004243 0.00422646 0.000320548"/>
            <joint name="joint3" pos="0 0 0" axis="0 -1 0" range="-0.01 4.71239" actuatorfrcrange="-100 100" damping="12.0" armature="0.06"/>
            <geom name="link3-4_visual" class="arm_visual" mesh="link3-4"/>
            <body name="link4-5" pos="0.244004 0 0.059971">
              <inertial pos="0.040231 0.0044807 0.035335" quat="0.911288 -0.0751532 0.308689 -0.261949" mass="0.4232" diaginertia="0.000275643 0.00021286 7.14977e-05"/>
              <joint name="joint4" pos="0 0 0" axis="0 -1 0" range="-1.95 1.5708" actuatorfrcrange="-20 20" damping="7.0" armature="0.025"/>
              <geom name="link4-5_visual" class="arm_visual" mesh="link4-5"/>
              <body name="link5-6" pos="0.061868 0 0.0425">
                <inertial pos="0.003612 0 0" quat="0.998188 0 -0.0601752 0" mass="0.4214" diaginertia="0.000838471 0.00082 0.000251529"/>
                <joint name="joint5" pos="0 0 0" axis="0 0 -1" range="-1.5708 1.5708" actuatorfrcrange="-20 20" damping="4.5" armature="0.015"/>
                <geom name="link5-6_visual" class="arm_visual" mesh="link5-6"/>
                <body name="link6-7" pos="0.032 0 -0.0425">
                  <inertial pos="0.041697 2.4368e-05 0.00014464" quat="0.5 0.5 -0.5 0.5" mass="0.8506" diaginertia="0.0005 0.00038 0.00028"/>
                  <joint name="joint6" pos="0 0 0" axis="1 0 0" range="-3.14159 3.14159" actuatorfrcrange="-20 20" damping="4.0" armature="0.01"/>
                  <geom name="link6-7_visual" class="arm_visual" mesh="link6-7"/>
                  <body name="finger_left">
                    <inertial pos="0.08 0.04 0" quat="0.5 0.5 0.5 0.5" mass="0.05" diaginertia="3e-05 3e-05 2e-05"/>
                    <joint name="gripper_left" pos="0 0 0" axis="0 1 0" type="slide" range="-0.045 0.001" actuatorfrcrange="-20 20" damping="2.0" armature="0.005"/>
                    <geom name="finger_left_visual" class="finger_visual" mesh="finger_left"/>
                    <geom name="finger_left_collision" class="finger_collision" pos="0.085 0.040 0" size="0.045 0.008 0.012"/>
                    <geom name="finger_left_inner_pad" class="finger_pad" pos="0.085 0.029 0" size="0.030 0.0025 0.010"/>
                  </body>
                  <body name="finger_right">
                    <inertial pos="0.08 -0.04 0" quat="0.5 0.5 0.5 0.5" mass="0.05" diaginertia="3e-05 3e-05 2e-05"/>
                    <joint name="gripper_right" pos="0 0 0" axis="0 -1 0" type="slide" range="-0.045 0.001" actuatorfrcrange="-20 20" damping="2.0" armature="0.005"/>
                    <geom name="finger_right_visual" class="finger_visual" mesh="finger_right"/>
                    <geom name="finger_right_collision" class="finger_collision" pos="0.085 -0.040 0" size="0.045 0.008 0.012"/>
                    <geom name="finger_right_inner_pad" class="finger_pad" pos="0.085 -0.029 0" size="0.030 0.0025 0.010"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="act_joint1" class="joint_position" joint="joint1" ctrlrange="-2.0944 2.0944" forcerange="-100 100"/>
    <position name="act_joint2" class="joint_position" joint="joint2" ctrlrange="-3.14159 0.01" forcerange="-100 100"/>
    <position name="act_joint3" class="joint_position" joint="joint3" ctrlrange="-0.01 4.71239" forcerange="-100 100"/>
    <position name="act_joint4" class="joint_position" joint="joint4" ctrlrange="-1.95 1.5708" forcerange="-20 20"/>
    <position name="act_joint5" class="joint_position" joint="joint5" ctrlrange="-1.5708 1.5708" forcerange="-20 20"/>
    <position name="act_joint6" class="joint_position" joint="joint6" ctrlrange="-3.14159 3.14159" forcerange="-20 20"/>
    <position name="act_gripper_left" class="joint_position" joint="gripper_left" ctrlrange="-0.045 0.001" forcerange="-20 20"/>
    <position name="act_gripper_right" class="joint_position" joint="gripper_right" ctrlrange="-0.045 0.001" forcerange="-20 20"/>
  </actuator>

  <contact>
    <!-- Exclude erroneous self-collisions present at the home pose; they pin joint1 and create drift. -->
    <exclude body1="arm_base" body2="link1-2"/>
    <exclude body1="link2-3" body2="link5-6"/>
    <!-- Parallel fingers are rail-constrained; letting them collide with each other destabilizes close/open control. -->
    <exclude body1="finger_left" body2="finger_right"/>
    <!-- Folded home posture should not solve this internal self-contact pair. -->
    <exclude body1="link1-2" body2="link5-6"/>
  </contact>

  <keyframe>
    <key name="home" qpos="0 0 0 0 0 0 0.001 0.001" ctrl="0 0 0 0 0 0 0.001 0.001"/>
  </keyframe>
</mujoco>
